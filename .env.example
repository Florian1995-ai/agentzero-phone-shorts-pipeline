# Optional LLM metadata/title analysis.
# Leave blank to use local fallback metadata and nugget selection.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_HTTP_REFERER=https://example.com/agentzero-phone-shorts
LLM_MAX_COST_PER_JOB_USD=0.20

# Upload/render server.
AGENTZERO_UPLOAD_DIR=/app/work_dir/assets/agentzero_uploads/shorts_test
AGENTZERO_OUTPUT_DIR=/app/work_dir/assets/agentzero_outputs
AGENTZERO_PIPELINE_DIR=/app/work_dir/assets/agentzero_pipeline
AGENTZERO_PIPELINE_CONFIG=/app/work_dir/assets/agentzero_pipeline/pipeline_config.json
AGENTZERO_UPLOAD_HOST=0.0.0.0
AGENTZERO_UPLOAD_PORT=8080
AGENTZERO_PIPELINE_SYNC_CODE=false

# Local Whisper model: tiny, base, small, medium.
WHISPER_MODEL=base

# Optional YouTube upload. Keep false until OAuth is set up.
YOUTUBE_UPLOAD_ENABLED=false
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=27
YOUTUBE_CREDENTIALS_PATH=/app/work_dir/assets/youtube/credentials.json
YOUTUBE_TOKEN_PATH=/app/work_dir/assets/youtube/token.json
