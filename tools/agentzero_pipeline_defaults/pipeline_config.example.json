    "rapid_cut_whoosh": "/app/work_dir/assets/agentzero_pipeline/audio/brand/soundreality-whoosh-bamboo-389752.mp3",
    "logo_whoosh": "/app/work_dir/assets/agentzero_pipeline/audio/brand/lordsonny-whoosh-cinematic-161021.mp3",
    "logo_reveal_chime": "/app/work_dir/assets/agentzero_pipeline/audio/brand/soft-bell-ding-485895.mp3",
    "alternate_logo_reveal_chime": "/app/work_dir/assets/agentzero_pipeline/audio/brand/intro-sound-2-269294.mp3",
    "music_bed": "/app/work_dir/assets/agentzero_pipeline/audio/music_bed.wav",
    "chime_volume": 0.26,
    "whoosh_volume": 0.2,
